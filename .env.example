# Kairos - Variables de Entorno
# Copiar este archivo como .env y ajustar los valores

DEBUG=True
SECRET_KEY=django-insecure-change-this-in-production
ALLOWED_HOSTS=127.0.0.1,localhost

# SQL Server con Windows Authentication (Trusted_Connection)
DB_ENGINE=mssql
DB_NAME=viva1a_db
DB_HOST=localhost\SQLEXPRESS
DB_OPTIONS_DRIVER=ODBC Driver 17 for SQL Server
DB_OPTIONS_TRUST_CERT=True
DB_OPTIONS_EXTRA_PARAMS=Trusted_Connection=yes;

# SQL Server con autenticacion SQL (descomentar y ajustar)
# DB_USER=sa
# DB_PASSWORD=Admin1234!
# DB_PORT=1433

# Base de datos externa KACTUS para integracion de empleados
# KACTUS_DB_NAME=KACTUS
# KACTUS_DB_USER=seven
# KACTUS_DB_PASSWORD=SevenIps1a*
# KACTUS_DB_HOST=172.27.198.73
# KACTUS_DB_PORT=
# KACTUS_DB_EXTRA_PARAMS=Encrypt=no;TrustServerCertificate=yes;

# Timezone
TIME_ZONE=America/Bogota
