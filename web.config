<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>
    <rewrite>
      <rules>
        <!-- Proxy todo a uvicorn -->
        <rule name="Proxy" stopProcessing="true">
          <match url="(.*)" />
          <conditions>
            <!-- Si NO es archivo estático, va al proxy -->
            <add input="{REQUEST_URI}" pattern="^/static/" negate="true" />
            <add input="{REQUEST_URI}" pattern="^/media/" negate="true" />
          </conditions>
          <action type="Rewrite" url="http://localhost:8000/{R:1}" />
        </rule>
      </rules>
    </rewrite>

    <!-- Proxy settings para WebSockets -->
    <proxy enabled="true" preserveHostHeader="true" />

    <!-- Servir estáticos directo desde el sistema de archivos -->
    <handlers accessPolicy="Read, Script">
      <add name="StaticFiles" path="static/*" verb="*" modules="StaticFileModule" resourceType="File" requireAccess="Read" />
      <add name="MediaFiles" path="media/*" verb="*" modules="StaticFileModule" resourceType="File" requireAccess="Read" />
    </handlers>
  </system.webServer>
</configuration>
